// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  PESERTA
}

enum StatusPendaftaran {
  MENUNGGU_PEMBAYARAN    // baru daftar, belum upload bukti
  MENUNGGU_VERIFIKASI    // sudah upload bukti, tunggu admin
  AKTIF                  // admin approve
  SELESAI                // sertifikasi selesai diikuti
  DITOLAK                // admin tolak (lihat catatanAdmin)
}

enum StatusPembayaran {
  BELUM_BAYAR
  MENUNGGU_KONFIRMASI    // sudah upload bukti
  LUNAS                  // admin konfirmasi
  DIKEMBALIKAN
}

enum TipeDokumen {
  KTP
  IJAZAH
  FOTO
  BUKTI_BAYAR
  SKEMA
  LAINNYA
}

enum MetodePembayaran {
  TRANSFER_BANK
  TUNAI
  LAINNYA
}

enum StatusPendaftaranPublik {
  BARU
  DIPROSES
  SELESAI
  DITOLAK
}

// ─────────────────────────────────────────────
// NEXTAUTH — User & Auth Models
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(PESERTA)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  peserta  Peserta?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// PESERTA PROFILE
// ─────────────────────────────────────────────

model Peserta {
  id           String    @id @default(cuid())
  userId       String    @unique
  nik          String?   // tidak unique — satu orang bisa daftar ulang setelah data diupdate
  tempatLahir  String?
  tanggalLahir DateTime?
  jenisKelamin String?
  alamat       String?   @db.Text
  kota         String?
  provinsi     String?
  noTelepon    String?
  perusahaan   String?
  jabatan      String?
  fotoUrl      String?   // Cloudinary URL foto profil
  fotoId       String?   // Cloudinary public ID untuk delete
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pendaftaran Pendaftaran[]
  dokumen     Dokumen[]

  @@map("peserta")
}

// ─────────────────────────────────────────────
// SERTIFIKASI
// ─────────────────────────────────────────────

model Sertifikasi {
  id        Int      @id @default(autoincrement())
  nama      String
  slug      String   @unique
  kategori  String
  deskripsi String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tingkatan   Tingkatan[]
  jadwal      Jadwal[]
  pendaftaran Pendaftaran[]

  @@map("sertifikasi")
}

model Tingkatan {
  id              Int      @id @default(autoincrement())
  sertifikasiId   Int
  nama            String
  tarif           Int
  dokumenSkemaUrl String?
  dokumenSkemaId  String?
  durasi          Int?
  kuota           Int      @default(20)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  sertifikasi Sertifikasi   @relation(fields: [sertifikasiId], references: [id], onDelete: Cascade)
  jadwal      Jadwal[]
  pendaftaran Pendaftaran[]

  @@map("tingkatan")
}

model Jadwal {
  id                Int      @id @default(autoincrement())
  sertifikasiId     Int
  tingkatanId       Int?
  tanggalMulai      DateTime
  tanggalSelesai    DateTime
  lokasi            String?
  metodePelaksanaan String   @default("Offline")
  kuotaTersedia     Int      @default(20)
  isPublished       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  sertifikasi Sertifikasi   @relation(fields: [sertifikasiId], references: [id], onDelete: Cascade)
  tingkatan   Tingkatan?    @relation(fields: [tingkatanId], references: [id])
  pendaftaran Pendaftaran[]

  @@map("jadwal")
}

// ─────────────────────────────────────────────
// PENDAFTARAN
// ─────────────────────────────────────────────

model Pendaftaran {
  id               String            @id @default(cuid())
  noPendaftaran    String            @unique // format: ASE-2025-0001
  pesertaId        String
  sertifikasiId    Int
  tingkatanId      Int
  jadwalId         Int?
  status           StatusPendaftaran @default(MENUNGGU_PEMBAYARAN)
  statusPembayaran StatusPembayaran  @default(BELUM_BAYAR)
  totalBiaya       Int
  catatan          String?           @db.Text  // catatan peserta saat daftar
  catatanAdmin     String?           @db.Text  // alasan tolak / catatan verifikasi
  verifikasiOleh   String?           // userId admin yang verifikasi
  verifikasiAt     DateTime?         // kapan diverifikasi
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  peserta     Peserta     @relation(fields: [pesertaId], references: [id])
  sertifikasi Sertifikasi @relation(fields: [sertifikasiId], references: [id])
  tingkatan   Tingkatan   @relation(fields: [tingkatanId], references: [id])
  jadwal      Jadwal?     @relation(fields: [jadwalId], references: [id])
  dokumen     Dokumen[]
  pembayaran  Pembayaran[]

  @@index([pesertaId])
  @@index([status])
  @@index([statusPembayaran])
  @@index([jadwalId])
  @@map("pendaftaran")
}

// ─────────────────────────────────────────────
// DOKUMEN — Cloudinary
// ─────────────────────────────────────────────

model Dokumen {
  id            String      @id @default(cuid())
  pesertaId     String?
  pendaftaranId String?
  nama          String
  tipe          TipeDokumen
  cloudinaryId  String
  cloudinaryUrl String
  fileSize      Int?
  mimeType      String?
  isVerified    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  peserta     Peserta?     @relation(fields: [pesertaId], references: [id])
  pendaftaran Pendaftaran? @relation(fields: [pendaftaranId], references: [id])

  @@index([pendaftaranId, tipe])
  @@map("dokumen")
}

// ─────────────────────────────────────────────
// PEMBAYARAN
// ─────────────────────────────────────────────

model Pembayaran {
  id                 String           @id @default(cuid())
  pendaftaranId      String
  jumlah             Int
  metodePembayaran   MetodePembayaran @default(TRANSFER_BANK)
  buktiCloudinaryId  String?
  buktiCloudinaryUrl String?
  tanggalBayar       DateTime?
  dikonfirmasiOleh   String?          // userId admin
  dikonfirmasiAt     DateTime?
  catatan            String?          @db.Text // misal nama rekening pengirim
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  pendaftaran Pendaftaran @relation(fields: [pendaftaranId], references: [id])

  @@index([pendaftaranId])
  @@map("pembayaran")
}

model PendaftaranPublik {
  id               String   @id @default(cuid())
  noPendaftaran    String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Data Diri
  namaLengkap      String
  email            String
  nik              String
  noHp             String
  tempatLahir      String
  tanggalLahir     String
  jenisKelamin     String
  alamat           String   @db.Text
  kodePos          String
  pendidikan       String

  // Sertifikasi
  skema            String
  metode           String

  // Referral
  penanggungjawab  String   @db.Text

  // Dokumen Cloudinary
  ktpUrl           String?
  ktpPublicId      String?
  ijazahUrl        String?
  ijazahPublicId   String?
  pasFotoUrl       String?
  pasFotoPublicId  String?
  suratUrl         String?
  suratPublicId    String?

  // Status admin
  status           StatusPendaftaranPublik @default(BARU)
  catatanAdmin     String?  @db.Text

  @@index([status])
  @@index([createdAt])
  @@map("pendaftaran_publik")
}